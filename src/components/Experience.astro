// Redes sociales para la barra lateral
const socialLinks = [
  { name: "github", url: "https://github.com/cheems-dev", icon: "simple-icons:github" },
  { name: "linkedin", url: "https://www.linkedin.com/in/luis-c-2b6b19171/", icon: "simple-icons:linkedin" },
  { name: "instagram", url: "https://www.instagram.com/lucho.dev.pe/", icon: "simple-icons:instagram" }
];
---

<section id="experience" class="py-20 bg-ferxxo-black relative overflow-hidden">
  <!-- Barra lateral de redes sociales (sticky) -->
  <div class="fixed left-0 top-1/2 transform -translate-y-1/2 z-[9999] hidden md:block">
    <div class="social-sidebar bg-ferxxo-black/80 backdrop-blur-sm p-3 rounded-r-xl border-r border-t border-b border-ferxxo-pink/30">
      <ul class="flex flex-col gap-4">
        {socialLinks.map((social) => (
          <li>
            <a 
              href={social.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="social-icon-link block p-2 rounded-full bg-ferxxo-black/50 border border-ferxxo-blue/20 hover:border-ferxxo-pink transition-all duration-300 hover:scale-110 hover:rotate-6"
              aria-label={`Visitar ${social.name}`}
            >
              <Icon name={social.icon} class="w-5 h-5 text-ferxxo-blue social-icon-glow" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Barra de redes sociales móvil (bottom) -->
  <div class="fixed bottom-0 left-0 right-0 z-[50] md:hidden">
    <div class="social-mobile bg-ferxxo-black/95 backdrop-blur-md py-3 px-4 border-t border-ferxxo-pink/30">
      <ul class="flex justify-center items-center gap-8">
        {socialLinks.map((social) => (
          <li>
            <a 
              href={social.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="social-icon-link flex items-center justify-center w-12 h-12 rounded-full bg-ferxxo-black/60 border border-ferxxo-blue/20 hover:border-ferxxo-pink transition-all duration-300"
              aria-label={`Visitar ${social.name}`}
            >
              <Icon name={social.icon} class="w-5 h-5 text-ferxxo-blue social-icon-glow" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Elementos decorativos de fondo -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-0 left-0 right-0 h-64 bg-gradient-to-br from-ferxxo-purple/10 via-transparent to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full bg-ferxxo-blue/5 blur-3xl opacity-20"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <!-- Encabezado de sección -->
    <div class="text-center mb-12 md:mb-16">
      <h2
        class="text-[clamp(2rem,4.5vw,3rem)] font-bold mb-4 uppercase text-white"
        style="font-family: var(--font-display);"
        data-aos="fade-up"
      >
        Mi <span class="text-ferxxo-pink ferxxo-glow">Experiencia</span>
      </h2>
      <div 
        class="w-32 h-1 bg-gradient-to-r from-ferxxo-pink via-ferxxo-purple to-ferxxo-blue mx-auto"
        data-aos="zoom-in"
        data-aos-delay="200"
      ></div>
      <p 
        class="mt-6 max-w-2xl mx-auto text-gray-300 md:text-lg"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        Mi trayectoria profesional y proyectos destacados que he desarrollado durante mi carrera.
      </p>
    </div>
    
    <!-- Timeline de experiencia con proyectos -->
    <div class="max-w-6xl mx-auto">
      {experiences.map((experience, index) => (
        <div class="mb-16 md:mb-24 ferxxo-fade-in" data-aos="fade-up" data-aos-delay={index * 150}>
          <div class="relative">
            <!-- Línea temporal (visible en tablets y desktop) -->
            <div class="hidden sm:block absolute left-16 md:left-1/3 top-0 bottom-0 w-0.5 bg-gradient-to-b from-ferxxo-blue via-ferxxo-purple to-ferxxo-pink opacity-30"></div>
            
            <!-- Contenido de la experiencia con proyectos -->
            <div class="flex flex-col sm:flex-row gap-8">
              <!-- Información de la empresa -->
              <div class="w-full sm:w-56 md:w-1/3 relative">
                <!-- Marcador de timeline (visible en tablets y desktop) -->
                <div class="hidden sm:flex absolute right-0 top-6 w-8 h-8 -translate-x-[calc(50%-0.125rem)] transform z-10 items-center justify-center">
                  <span class="w-3 h-3 rounded-full bg-ferxxo-blue absolute"></span>
                  <span class="w-5 h-5 rounded-full bg-ferxxo-blue/30 absolute animate-ping"></span>
                </div>
                
                <div class="bg-ferxxo-black/70 backdrop-blur-sm p-6 rounded-xl border border-ferxxo-blue/20 hover:border-ferxxo-blue/40 transition-all duration-300 h-full hover:shadow-[0_0_15px_rgba(0,240,255,0.15)]">
                  <span class="inline-block px-3 py-1 text-sm font-semibold bg-ferxxo-pink/10 text-ferxxo-pink rounded-full mb-3 border border-ferxxo-pink/30">
                    {experience.period}
                  </span>
                  <h3 class="text-xl md:text-2xl font-bold text-white mb-2">
                    {experience.position}
                  </h3>
                  <h4 class="text-lg font-medium text-ferxxo-blue mb-4">
                    {experience.company}
                  </h4>
                  <p class="text-gray-300 text-sm md:text-base mb-4">
                    {experience.description}
                  </p>
                </div>
              </div>
              
              <!-- Proyectos de esta experiencia -->
              <div class="w-full sm:flex-1 md:w-2/3 pl-0 sm:pl-12 md:pl-6">
                <h4 class="text-lg md:text-xl font-bold text-white mb-6 flex items-center">
                  <span class="inline-block w-5 h-0.5 bg-ferxxo-pink mr-3"></span>
                  Proyectos Destacados
                </h4>
                
                <ExperienceProjectGrid
                  projects={experience.projects.map(p => ({
                    name: p.name,
                    description: p.description,
                    image: { src: p.image.src, width: p.image.width, height: p.image.height },
                    technologies: p.technologies,
                    link: p.link
                  }))}
                  client:load
                />
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<style>
  .ferxxo-glow {
    position: relative;
    text-shadow: 0 0 10px currentColor;
  }
  
  @keyframes neon-flicker {
    0%, 100% { opacity: 1; }
    41.99% { opacity: 1; }
    42% { opacity: 0.8; }
    43% { opacity: 1; }
    47% { opacity: 1; }
    47.1% { opacity: 0.9; }
    47.2% { opacity: 1; }
    60.99% { opacity: 1; }
    61% { opacity: 0.8; }
    61.5% { opacity: 1; }
  }
  
  .project-card {
    position: relative;
    z-index: 1 !important;
  }
  
  /* Asegurar jerarquía correcta de z-index */
  .social-sidebar {
    z-index: 9999 !important;
  }
  
  .social-mobile {
    z-index: 50 !important;
  }
  
  .project-title {
    text-shadow: 0 0 10px rgba(0, 240, 255, 0.7), 0 0 20px rgba(0, 240, 255, 0.5);
    animation: pulse 2s infinite;
  }
  
  .text-shadow {
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.8);
  }
  
  .text-shadow-sm {
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
  }
  
  .ferxxo-neon-card {
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 15px rgba(255, 0, 128, 0.3);
  }
  
  .ferxxo-neon-text {
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 
      0 0 5px #ff00ff,
      0 0 10px #ff00ff,
      0 0 20px #ff00ff;
    animation: neon-text-pulse 2s infinite alternate;
  }
  
  .neon-glow-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 0, 128, 0.1), rgba(80, 0, 255, 0.1));
    opacity: 0.5;
    z-index: -1;
    filter: blur(8px);
    animation: glow-pulse 3s infinite alternate;
  }
  
  .social-icon-glow {
    filter: drop-shadow(0 0 2px currentColor);
    transition: all 0.3s;
  }
  
  .social-icon-link:hover .social-icon-glow {
    filter: drop-shadow(0 0 5px #ff00ff);
    color: #ff00ff;
  }
  
  .social-sidebar {
    box-shadow: 4px 0 15px rgba(255, 0, 128, 0.2);
    animation: sidebar-glow 4s infinite alternate;
    margin: 0;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.8; }
  }
  
  @keyframes neon-text-pulse {
    0% { text-shadow: 0 0 5px #ff00ff, 0 0 10px #ff00ff, 0 0 20px #ff00ff; }
    100% { text-shadow: 0 0 2px #ff00ff, 0 0 5px #ff00ff, 0 0 10px #ff00ff; }
  }
  
  @keyframes glow-pulse {
    0% { opacity: 0.3; filter: blur(8px); }
    100% { opacity: 0.7; filter: blur(12px); }
  }
  
  @keyframes sidebar-glow {
    0% { box-shadow: 4px 0 15px rgba(255, 0, 128, 0.2); }
    50% { box-shadow: 4px 0 15px rgba(0, 240, 255, 0.2); }
    100% { box-shadow: 4px 0 15px rgba(255, 0, 128, 0.2); }
  }
  
</style>

 